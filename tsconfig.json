{
    "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "baseUrl": ""
    },
    "include": ["tests/**/*.ts", "pages/**/*.ts", "utils/*/*.ts"],
    "exclude": ["node_modules", "dist"]
}